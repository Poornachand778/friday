# AWS Credentials for SageMaker (Optional - use instead of aws configure)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# SageMaker Configuration
SAGEMAKER_ROLE=arn:aws:iam::YOUR_ACCOUNT_ID:role/service-role/AmazonSageMaker-ExecutionRole
S3_BUCKET=your-training-bucket
S3_PREFIX=friday-finetuning

# HuggingFace Access Token (Required for Meta-Llama models)
HUGGINGFACE_TOKEN=hf_your_token_here

# Model Configuration - Now using compatible versions for Llama-3.1
MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct
INSTANCE_TYPE=ml.g5.12xlarge
TRAINING_EPOCHS=1
LORA_RANK=16
LORA_ALPHA=32

# Local Development
LOCAL_MODEL_PATH=./models/hf/Meta-Llama-3.1-8B-Instruct
LOCAL_DATA_PATH=./data/instructions
