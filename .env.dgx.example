# Friday AI - DGX Spark Environment Variables
# =============================================
# Copy to .env.dgx and fill in your values:
#   cp .env.dgx.example .env.dgx
#
# Then launch:
#   docker compose -f docker-compose.dgx.yaml --env-file .env.dgx up -d

# === Required ===

# PostgreSQL password (set a strong password)
POSTGRES_PASSWORD=changeme_friday_2025

# HuggingFace token (needs access to LLaMA 3.1)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# === Optional ===

# PostgreSQL
POSTGRES_USER=friday
POSTGRES_DB=friday

# LLM model (default: LLaMA 3.1 8B Instruct)
# On DGX Spark with 128GB, you can also use:
#   meta-llama/Meta-Llama-3.1-70B-Instruct
#   deepseek-ai/DeepSeek-R1-0528
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# GLM Router (optional - for intelligent request routing)
ROUTER_ENABLED=false
ROUTER_PROVIDER=zhipu
ROUTER_API_KEY=

# AWS (only if using S3 for cloud storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
